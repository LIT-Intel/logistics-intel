# Public site URL — used by sitemap, OG images, canonical tags
NEXT_PUBLIC_SITE_URL=https://logisticintel.com
NEXT_PUBLIC_APP_URL=https://app.logisticintel.com

# Sanity CMS
# Create a project at sanity.io/manage and paste the project ID here
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-15
# Read token (optional, only needed for previewDrafts perspective)
SANITY_API_READ_TOKEN=
# Write token used by AI agent fleet + seed scripts
SANITY_API_WRITE_TOKEN=

# logo.dev — for company logos (industry, integrations, customer rail)
# Get a key at https://www.logo.dev/
NEXT_PUBLIC_LOGO_DEV_KEY=
# logo.dev publishable token. Public, OK to commit. Get a new one at https://www.logo.dev/dashboard if rotating.
NEXT_PUBLIC_LOGO_DEV_TOKEN=pk_X-1ZO13GSgeOoUrIuJ6GMQ

# Anthropic API — used by AI agent fleet (TradeLane Refresher,
# Blog Drafter, Glossary Expander, etc). Server-side only.
ANTHROPIC_API_KEY=

# Vercel cron secret — protects /api/cron/* routes from public hits
CRON_SECRET=

# Optional — Plausible analytics domain for privacy-friendly tracking
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=logisticintel.com

# ---------------------------------------------------------------------------
# Lead capture — POST /api/leads/resend
# Required for the "money pages" lead-capture endpoint. See
# docs/marketing/resend-templates.md for template content + merge fields.
# ---------------------------------------------------------------------------

# Resend API key (already set for transactional emails in lib/email.ts)
RESEND_API_KEY=

# Optional — From address used by all Resend sends. Falls back to
# "Logistic Intel <hello@logisticintel.com>" if unset.
RESEND_FROM_EMAIL=

# Resend transactional template IDs. Create in the Resend dashboard, paste
# the template_id values here. The route picks one based on the `offer`
# field on the inbound POST.
RESEND_LIT_TRIAL_WELCOME_TEMPLATE_ID=
RESEND_LIT_TOP_100_TEMPLATE_ID=

# Optional — Direct download URL for the "Top 100 active shippers" PDF lead
# magnet. Falls back to https://logisticintel.com/lead-magnets/top-100-shippers.pdf
LIT_TOP_100_PDF_URL=

# Supabase service-role credentials (server-side only — already used by
# /api/demo-request). Required for inserting into public.lit_leads.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Resend Audiences — every captured lead is fanned out across 3 dimensions
# (funnel × industry × channel = 12 audiences). A single lead can join up
# to 3 audiences simultaneously (Resend Audiences are independent lists).
#
# To populate these: run `node scripts/setup-resend-audiences.cjs` once
# with RESEND_API_KEY in your shell env. It creates all 12 idempotently
# and emits a paste-ready env block.
#
# If a var is unset, the audience-add for that route is silently skipped —
# the lead capture itself never fails on a missing audience.
# ---------------------------------------------------------------------------

# ── Dimension 1: Funnel stage (drives drip sequence) ──────────────────────

# Default: hero / sticky / final CTA forms on money pages
RESEND_AUDIENCE_TRIAL_LEADS=

# offer === "top-100-shippers-pdf" (exit-intent lead magnet)
RESEND_AUDIENCE_TOP_100_PDF=

# source startsWith "partners-" (partner program applications)
RESEND_AUDIENCE_PARTNERS=

# source startsWith "customers-" | "vs-" | "alternatives-" | "best-"
RESEND_AUDIENCE_COMPARISON=

# ── Dimension 2: Industry / role (broadcast targeting) ────────────────────

# Inferred from form `role` field OR source starting with
# solutions-freight-forwarders / solutions-freight-brokers / etc.
RESEND_AUDIENCE_FORWARDERS=
RESEND_AUDIENCE_BROKERS=
RESEND_AUDIENCE_NVOCCS=
RESEND_AUDIENCE_3PLS=

# ── Dimension 3: Acquisition channel (broadcast targeting) ────────────────

# Inferred from utm_source / utm_medium / document.referrer captured
# client-side by useLeadMagnetForm.
# - PPC:     utm_source in {google-ads, linkedin-ads, meta-ads, bing-ads, ...}
# - SEO:     referrer from google.com / bing.com / duckduckgo.com / ...
# - Social:  utm_source in {linkedin, twitter, x, youtube, tiktok, ...}
#            OR referrer from linkedin.com / x.com / youtube.com / ...
# - Direct:  no utm + no referrer (or external non-search/non-social referrer)
RESEND_AUDIENCE_PPC=
RESEND_AUDIENCE_SEO=
RESEND_AUDIENCE_SOCIAL=
RESEND_AUDIENCE_DIRECT=

# ---------------------------------------------------------------------------
# Resend drip-sequence template IDs (resolved lazily at dispatch time by
# the sequence-dispatcher cron, so you can rotate them without redeploy).
# See marketing/lib/lead-sequences.ts for the full sequence definitions.
# ---------------------------------------------------------------------------

# trial-welcome (5 steps: 0h, 48h, 120h, 216h, 336h)
RESEND_TPL_TRIAL_WELCOME=
RESEND_TPL_TRIAL_DAY_2=
RESEND_TPL_TRIAL_DAY_5=
RESEND_TPL_TRIAL_DAY_9=
RESEND_TPL_TRIAL_DAY_14=

# top-100-followup (3 steps: 0h, 72h, 168h)
RESEND_TPL_TOP_100_DELIVERY=
RESEND_TPL_TOP_100_DAY_3=
RESEND_TPL_TOP_100_DAY_7=

# partner-onboarding (3 steps: 0h, 48h, 168h)
RESEND_TPL_PARTNER_RECEIVED=
RESEND_TPL_PARTNER_APPROVED=
RESEND_TPL_PARTNER_DAY_7=

# comparison-nurture (2 steps: 0h, 96h) — uses {{competitor}} merge token
# resolved from `source` at dispatch time
RESEND_TPL_COMPARISON_WELCOME=
RESEND_TPL_COMPARISON_DAY_4=
